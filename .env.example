# ===================================================
# 複製此檔案為 .env，並填入你的真實金鑰
# cp .env.example .env
# ===================================================

# OpenAI API 金鑰（必填）
# 取得方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...你的金鑰填這裡...

# LangSmith 追蹤（選填，用於觀測 Agent 執行過程）
# 取得方式：https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=ls__...你的金鑰填這裡...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-learning-advisor

# 模型設定
OPENAI_MODEL=gpt-4o

# FAISS 索引路徑（相對於專案根目錄）
FAISS_DB_PATH=faiss_db
